# ---------------------------------------------------------------------------
# .env.example — a template, NOT real secrets.
#
# This file is safe to keep in git because it only shows the NAMES of the
# settings login needs, with fake example values. The real values live in
# Railway (Variables tab) and, for local testing, in a private ".env" file
# that git ignores. Never put real keys in THIS file.
#
# See SETUP-LOGIN.md for step-by-step instructions on where each value comes
# from.
# ---------------------------------------------------------------------------

# Master switch. Leave "false" until every value below is filled in, then flip
# to "true" to turn login on. When "false", the whole site is public (today's
# behaviour).
AUTH_ENABLED=false

# From WorkOS → API Keys. The secret one, starts with "sk_".
WORKOS_API_KEY=sk_example_replace_me

# From WorkOS → API Keys / Overview. Starts with "client_".
WORKOS_CLIENT_ID=client_example_replace_me

# Any random string of at least 32 characters. It encrypts the login pass.
# Make one up (mash the keyboard) or generate one — see SETUP-LOGIN.md.
WORKOS_COOKIE_PASSWORD=change_me_to_32_or_more_random_chars

# Where WorkOS sends agents back after they click their magic link. It must end
# in /callback and exactly match what you enter in the WorkOS dashboard.
#   Local testing:  http://localhost:3000/callback
#   Live site:      https://ulgagency.com/callback
WORKOS_REDIRECT_URI=http://localhost:3000/callback

# The "Unity Life Group" organization in WorkOS — your roster of approved
# agents. Starts with "org_". Only members of this org can enter locked pages.
WORKOS_ORG_ID=org_example_replace_me
